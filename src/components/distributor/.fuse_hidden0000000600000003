import { useEffect, useMemo, useState } from "react";
import {
  Loader2, RefreshCw, Download, CalendarDays, Users, IndianRupee, Coins, CheckCircle2, Receipt,
  Banknote, Smartphone, Zap, Landmark, Plane, ShieldCheck, CreditCard, Droplets, FileText, Building2, Award,
} from "lucide-react";
import {
  LineChart, Line, ResponsiveContainer, XAxis, YAxis, Tooltip, CartesianGrid,
  PieChart, Pie, Cell, BarChart, Bar, LabelList,
} from "recharts";
import { supabase } from "@/integrations/supabase/client";
import { ensureStaffSession } from "@/integrations/supabase/ensure-session";
import { demoApps, demoRetailers, demoDashboard, distributorDemoOn } from "@/components/distributor/distributor-demo";

const inr = (n: number) => "₹" + Number(n || 0).toLocaleString("en-IN");
const inrK = (n: number) => n >= 1e5 ? `₹${(n / 1e5).toFixed(2)}L` : n >= 1000 ? `₹${(n / 1000).toFixed(0)}k` : `₹${n}`;
const COLORS = ["#3b82f6", "#22c55e", "#f59e0b", "#8b5cf6", "#06b6d4", "#ec4899", "#94a3b8", "#6366f1", "#14b8a6"];
const gp = (a: number, b: number) => (b > 0 ? ((a - b) / b) * 100 : a > 0 ? 100 : 0);
const gTxt = (n: number) => (n >= 0 ? `▲ ${n.toFixed(1)}%` : `▼ ${Math.abs(n).toFixed(1)}%`);
const catIcon = (name: string) => {
  const n = (name || "").toLowerCase();
  if (n.includes("aeps") || n.includes("cash")) return Banknote;
  if (n.includes("money") || n.includes("dmt") || n.includes("transfer")) return Receipt;
  if (n.includes("mobile") || n.includes("recharge")) return Smartphone;
  if (n.includes("dth")) return Zap;
  if (n.includes("electric") || n.includes("bill")) return Zap;
  if (n.includes("water")) return Droplets;
  if (n.includes("insurance")) return ShieldCheck;
  if (n.includes("pan")) return CreditCard;
  if (n.includes("gov")) return Landmark;
  if (n.includes("travel") || n.includes("booking")) return Plane;
  if (n.includes("bank")) return Building2;
  return FileText;
};

function Kpi({ icon: Icon, label, value, delta, labelColor, iconBg, iconColor }: any) {
  const up = (delta ?? 0) >= 0;
  return (
    <div className="rounded-2xl border border-border bg-card p-4 shadow-soft">
      <div className="flex items-start justify-between gap-2">
        <div className="min-w-0">
          <p className={`text-[11px] font-bold ${labelColor}`}>{label}</p>
          <p className="mt-1 text-2xl font-extrabold leading-tight">{value}</p>
          {delta != null && <p className={`mt-1 text-[11px] font-semibold ${up ? "text-emerald-600" : "text-rose-600"}`}>{gTxt(delta)} vs prev 30d</p>}
        </div>
        <span className={`grid h-10 w-10 shrink-0 place-items-center rounded-full ${iconBg}`}><Icon className={`h-5 w-5 ${iconColor}`} /></span>
      </div>
    </div>
  );
}

const medal = ["🥇", "🥈", "🥉"];

export function DistributorSalesDashboard() {
  const [apps, setApps] = useState<any[]>([]);
  const [retailers, setRetailers] = useState<any[]>([]);
  const [dash, setDash] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [demo, setDemo] = useState(false);

  async function load() {
    setLoading(true);
    try {
      await ensureStaffSession();
      const [a, r, d] = await Promise.all([
        supabase.rpc("distributor_applications"),
        supabase.rpc("distributor_retailers"),
        supabase.rpc("distributor_dashboard"),
      ]);
      const apps0 = (a.data as any[]) ?? [];
      const rets0 = (r.data as any[]) ?? [];
      if (apps0.length === 0) {
        // No real activity yet — show demo data so the portal previews fully.
        setApps(demoApps); setRetailers(demoRetailers); setDash(demoDashboard); setDemo(true);
      } else {
        setApps(apps0); setRetailers(rets0.length ? rets0 : demoRetailers); setDash((d.data as any) ?? {}); setDemo(false);
      }
    } finally { setLoading(false); }
  }
  useEffect(() => { load(); }, []);

  const m = useMemo(() => {
    const now = Date.now(), d30 = now - 30 * 864e5, d60 = now - 60 * 864e5;
    const ts = (x: any) => new Date(x.created_at).getTime();
    const charge = (x: any) => Number(x.service_charge || 0);
    const comm = (x: any) => Number(x.distributor_commission_amount || 0);
    const done = (x: any) => ["approved", "completed"].includes(x.status);

    const totalTxns = apps.length;
    const totalVol = apps.reduce((s, x) => s + charge(x), 0);
    const totalComm = apps.reduce((s, x) => s + comm(x), 0);
    const successRate = totalTxns > 0 ? (apps.filter(done).length / totalTxns) * 100 : 0;

    const thisA = apps.filter((x) => ts(x) >= d30), prevA = apps.filter((x) => ts(x) >= d60 && ts(x) < d30);
    const sum = (arr: any[], f: (x: any) => number) => arr.reduce((s, x) => s + f(x), 0);
    const succ = (arr: any[]) => arr.length > 0 ? (arr.filter(done).length / arr.length) * 100 : 0;
    const newR = (lo: number, hi: number) => retailers.filter((r) => { const t = new Date(r.created_at).getTime(); return t >= lo && t < hi; }).length;

    const growth = {
      txns: gp(thisA.length, prevA.length),
      vol: gp(sum(thisA, charge), sum(prevA, charge)),
      comm: gp(sum(thisA, comm), sum(prevA, comm)),
      retailers: gp(newR(d30, now + 1), newR(d60, d30)),
      success: succ(thisA) - succ(prevA),
    };

    // Service-wise performance (by category)
    const catMap = new Map<string, { name: string; txns: number; revenue: number; commission: number; tRev: number; pRev: number }>();
    for (const x of apps) {
      const k = x.category_name || x.service_name || "Other";
      const e = catMap.get(k) ?? { name: k, txns: 0, revenue: 0, commission: 0, tRev: 0, pRev: 0 };
      e.txns++; e.revenue += charge(x); e.commission += comm(x);
      if (ts(x) >= d30) e.tRev += charge(x); else if (ts(x) >= d60 && ts(x) < d30) e.pRev += charge(x);
      catMap.set(k, e);
    }
    const services = Array.from(catMap.values()).map((e) => ({ ...e, growth: gp(e.tRev, e.pRev) })).sort((a, b) => b.revenue - a.revenue);

    // Service contribution (donut) — top 6 + Others
    const topC = services.slice(0, 6);
    const restRev = services.slice(6).reduce((s, x) => s + x.revenue, 0);
    const contribution = restRev > 0 ? [...topC, { name: "Others", revenue: restRev }] : topC;

    // Business volume trend (last 30 days)
    const byDay = new Map<string, number>();
    for (let i = 29; i >= 0; i--) { const dt = new Date(now - i * 864e5); byDay.set(dt.toISOString().slice(0, 10), 0); }
    for (const x of apps) { const key = new Date(x.created_at).toISOString().slice(0, 10); if (byDay.has(key)) byDay.set(key, (byDay.get(key) || 0) + charge(x)); }
    const trend = Array.from(byDay.entries()).map(([d, v]) => ({ day: new Date(d).toLocaleDateString("en-IN", { day: "2-digit", month: "short" }), value: v }));

    // Top retailers by revenue
    const idByName = new Map<string, string>();
    const distByName = new Map<string, string>();
    for (const r of retailers) { idByName.set(r.name, r.retailer_id || "—"); distByName.set(r.name, r.district || "Other"); }
    const retMap = new Map<string, number>();
    for (const x of apps) { const k = x.retailer_name || "—"; retMap.set(k, (retMap.get(k) || 0) + charge(x)); }
    const topRetailers = Array.from(retMap.entries()).map(([name, revenue]) => ({ name, revenue, id: idByName.get(name) || "—" })).sort((a, b) => b.revenue - a.revenue).slice(0, 5);

    // Top districts by business volume
    const distMap = new Map<string, number>();
    for (const x of apps) { const k = distByName.get(x.retailer_name) || "Other"; distMap.set(k, (distMap.get(k) || 0) + charge(x)); }
    let districts = Array.from(distMap.entries()).map(([name, value]) => ({ name, value })).sort((a, b) => b.value - a.value);
    if (districts.length > 5) { const rest = districts.slice(5).reduce((s, x) => s + x.value, 0); districts = [...districts.slice(0, 5), { name: "Others", value: rest }]; }

    // Retailer summary
    const totalRetailers = retailers.length || Number(dash?.retailers ?? 0);
    const activeRetailers = retailers.length ? retailers.filter((r) => r.is_active).length : Number(dash?.active_retailers ?? 0);
    const inactiveRetailers = Math.max(0, totalRetailers - activeRetailers);

    return { totalTxns, totalVol, totalComm, successRate, growth, services, contribution, trend, topRetailers, districts, totalRetailers, activeRetailers, inactiveRetailers };
  }, [apps, retailers, dash]);

  const download = () => {
    const esc = (v: any) => `"${String(v ?? "").replace(/"/g, '""')}"`;
    const head = ["Service Category", "Transactions", "Revenue", "Commission", "Growth %"];
    const lines = m.services.map((s) => [s.name, s.txns, s.revenue, s.commission, s.growth.toFixed(1) + "%"].map(esc).join(","));
    const csv = ["﻿" + head.map(esc).join(","), ...lines].join("\n");
    const url = URL.createObjectURL(new Blob([csv], { type: "text/csv;charset=utf-8;" }));
    const a = document.createElement("a"); a.href = url; a.download = `distributor-sales-${new Date().toISOString().slice(0, 10)}.csv`; a.click(); URL.revokeObjectURL(url);
  };

  const totalContribution = m.contribution.reduce((s, x) => s + x.revenue, 0) || 1;

  return (
    <div className="space-y-4">
      {/* Header */}
      <div className="flex flex-wrap items-start justify-between gap-3">
        <div className="flex items-center gap-2.5">
          <span className="grid h-9 w-9 place-items-center rounded-xl bg-blue-600 text-white"><BarIcon /></span>
          <div>
            <h1 className="flex items-center gap-2 font-display text-2xl font-extrabold">Distributor Sales Dashboard {demo && <span className="rounded-full bg-amber-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-amber-700">Demo data</span>}</h1>
            <p className="text-sm text-muted-foreground">Overview of your business performance</p>
          </div>
        </div>
        <div className="flex items-center gap-2">
          <span className="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 h-10 text-xs font-semibold text-muted-foreground"><CalendarDays className="h-4 w-4" /> Last 30 days</span>
          <button onClick={download} className="inline-flex items-center gap-1.5 rounded-lg border border-border bg-card px-3 h-10 text-sm font-semibold hover:bg-muted"><Download className="h-4 w-4" /> Download Report</button>
          <button onClick={load} className="inline-flex items-center gap-1.5 rounded-lg border border-border px-3 h-10 text-sm font-semibold hover:bg-muted"><RefreshCw className={`h-4 w-4 ${loading ? "animate-spin" : ""}`} /> Refresh</button>
        </div>
      </div>

      {loading ? (
        <div className="flex items-center gap-2 py-10 text-sm text-muted-foreground"><Loader2 className="h-4 w-4 animate-spin" /> Loading…</div>
      ) : (
        <>
          {/* KPIs */}
          <div className="grid grid-cols-2 gap-3 md:grid-cols-3 xl:grid-cols-5">
            <Kpi icon={Users} label="Total Transactions" value={m.totalTxns.toLocaleString("en-IN")} delta={m.growth.txns} labelColor="text-blue-600" iconBg="bg-blue-100" iconColor="text-blue-600" />
            <Kpi icon={IndianRupee} label="Total Business Volume" value={inr(m.totalVol)} delta={m.growth.vol} labelColor="text-emerald-600" iconBg="bg-emerald-100" iconColor="text-emerald-600" />
            <Kpi icon={Coins} label="Total Commission Earned" value={inr(m.totalComm)} delta={m.growth.comm} labelColor="text-orange-600" iconBg="bg-orange-100" iconColor="text-orange-600" />
            <Kpi icon={Users} label="Active Retailers" value={m.activeRetailers.toLocaleString("en-IN")} delta={m.growth.retailers} labelColor="text-violet-600" iconBg="bg-violet-100" iconColor="text-violet-600" />
            <Kpi icon={CheckCircle2} label="Success Rate" value={`${m.successRate.toFixed(2)}%`} delta={m.growth.success} labelColor="text-teal-600" iconBg="bg-teal-100" iconColor="text-teal-600" />
          </div>

          {/* Service Wise Performance + Business Volume Trend / Service Contribution */}
          <div className="grid gap-3 lg:grid-cols-2">
            {/* Performance table */}
            <div className="rounded-2xl border border-border bg-card p-5 shadow-soft">
              <p className="mb-3 text-sm font-bold">Service Wise Performance</p>
              <div className="overflow-x-auto">
                <table className="w-full text-sm">
                  <thead className="text-left text-[11px] uppercase tracking-wide text-muted-foreground">
                    <tr><th className="py-2 pr-2">Service Category</th><th className="py-2 pr-2 text-right">Transactions</th><th className="py-2 pr-2 text-right">Revenue (₹)</th><th className="py-2 pr-2 text-right">Commission (₹)</th><th className="py-2 text-right">Growth</th></tr>
                  </thead>
                  <tbody>
                    {m.services.length === 0 ? <tr><td colSpan={5} className="py-8 text-center text-muted-foreground">No service activity yet.</td></tr> : m.services.map((s, i) => {
                      const Ic = catIcon(s.name);
                      return (
                        <tr key={s.name} className="border-t border-border/70">
                          <td className="py-2 pr-2"><span className="inline-flex items-center gap-2 font-semibold"><span className="grid h-6 w-6 place-items-center rounded-md bg-muted text-muted-foreground"><Ic className="h-3.5 w-3.5" /></span>{s.name}</span></td>
                          <td className="py-2 pr-2 text-right">{s.txns.toLocaleString("en-IN")}</td>
                          <td className="py-2 pr-2 text-right">{Number(s.revenue).toLocaleString("en-IN")}</td>
                          <td className="py-2 pr-2 text-right">{Number(s.commission).toLocaleString("en-IN")}</td>
                          <td className={`py-2 text-right font-semibold ${s.growth >= 0 ? "text-emerald-600" : "text-rose-600"}`}>{gTxt(s.growth)}</td>
                        </tr>
                      );
                    })}
                    {m.services.length > 0 && (
                      <tr className="border-t-2 border-border font-bold">
                        <td className="py-2 pr-2">Total</td>
                        <td className="py-2 pr-2 text-right">{m.totalTxns.toLocaleString("en-IN")}</td>
                        <td className="py-2 pr-2 text-right">{Number(m.totalVol).toLocaleString("en-IN")}</td>
                        <td className="py-2 pr-2 text-right">{Number(m.totalComm).toLocaleString("en-IN")}</td>
                        <td className={`py-2 text-right ${m.growth.vol >= 0 ? "text-emerald-600" : "text-rose-600"}`}>{gTxt(m.growth.vol)}</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            </div>

            {/* Trend + contribution stacked */}
            <div className="space-y-3">
              <div className="rounded-2xl border border-border bg-card p-5 shadow-soft">
                <div className="mb-1 flex items-center justify-between"><p className="text-sm font-bold">Business Volume Trend (₹)</p><span className="rounded-lg border border-border bg-muted/40 px-2.5 py-1 text-xs font-semibold text-muted-foreground">Daily</span></div>
                <div className="h-44">
                  {m.trend.every((t) => t.value === 0) ? <div className="grid h-full place-items-center text-xs text-muted-foreground">No volume in the last 30 days.</div> : (
                    <ResponsiveContainer width="100%" height="100%">
                      <LineChart data={m.trend} margin={{ top: 10, right: 10, left: -6, bottom: 0 }}>
                        <CartesianGrid strokeDasharray="3 3" stroke="#eef2f7" vertical={false} />
                        <XAxis dataKey="day" tickLine={false} axisLine={false} className="text-[10px]" interval={4} />
                        <YAxis tickLine={false} axisLine={false} className="text-[10px]" tickFormatter={(v) => `${(v / 1000).toFixed(0)}k`} />
                        <Tooltip formatter={(v: number) => inr(v)} contentStyle={{ borderRadius: 8, border: "1px solid hsl(var(--border))", fontSize: 12 }} />
                        <Line type="monotone" dataKey="value" name="Business Volume (₹)" stroke="#3b82f6" strokeWidth={2} dot={{ r: 2 }} />
                      </LineChart>
                    </ResponsiveContainer>
                  )}
                </div>
              </div>
              <div className="rounded-2xl border border-border bg-card p-5 shadow-soft">
                <p className="mb-1 text-sm font-bold">Service Contribution (by Revenue)</p>
                <div className="flex items-center gap-3">
                  <div className="relative h-40 w-40 shrink-0">
                    {m.contribution.length === 0 ? <div className="grid h-full place-items-center text-xs text-muted-foreground">No data</div> : (
                      <>
                        <ResponsiveContainer width="100%" height="100%">
                          <PieChart>
                            <Pie data={m.contribution} dataKey="revenue" nameKey="name" innerRadius={48} outerRadius={68} paddingAngle={2}>
                              {m.contribution.map((_, i) => <Cell key={i} fill={COLORS[i % COLORS.length]} />)}
                            </Pie>
                            <Tooltip formatter={(v: number) => inr(v)} />
                          </PieChart>
                        </ResponsiveContainer>
                        <div className="pointer-events-none absolute inset-0 grid place-items-center"><div className="text-center"><p className="text-[11px] font-extrabold">{inr(m.totalVol)}</p><p className="text-[9px] text-muted-foreground">Total</p></div></div>
                      </>
                    )}
                  </div>
                  <div className="min-w-0 flex-1 space-y-1">
                    {m.contribution.map((s, i) => (
                      <div key={s.name} className="flex items-center gap-2 text-[11px]"><span className="h-2.5 w-2.5 rounded-full" style={{ background: COLORS[i % COLORS.length] }} /><span className="flex-1 truncate text-muted-foreground">{s.name}</span><span className="font-semibold">{((s.revenue / totalContribution) * 100).toFixed(1)}%</span></div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          {/* Bottom row: Top retailers + Retailer summary + Top districts */}
          <div className="grid gap-3 lg:grid-cols-3">
            <div className="rounded-2xl border border-border bg-card p-5 shadow-soft">
              <p className="mb-3 text-sm font-bold">Top 5 Retailers by Revenue</p>
              <table className="w-full text-sm">
                <thead className="text-left text-[11px] uppercase tracking-wide text-muted-foreground"><tr><th className="py-1.5 pr-2">Rank</th><th className="py-1.5 pr-2">Retailer ID</th><th className="py-1.5 pr-2">Retailer Name</th><th className="py-1.5 text-right">Revenue (₹)</th></tr></thead>
                <tbody>
                  {m.topRetailers.length === 0 ? <tr><td colSpan={4} className="py-6 text-center text-muted-foreground">No data</td></tr> : m.topRetailers.map((r, i) => (
                    <tr key={r.name + i} className="border-t border-border/70">
                      <td className="py-2 pr-2">{i < 3 ? <span className="text-base">{medal[i]}</span> : <span className="grid h-5 w-5 place-items-center rounded-full bg-muted text-[11px] font-bold text-muted-foreground">{i + 1}</span>}</td>
                      <td className="py-2 pr-2 font-mono text-xs">{r.id}</td>
                      <td className="py-2 pr-2 font-semibold">{r.name}</td>
                      <td className="py-2 text-right font-semibold">{Number(r.revenue).toLocaleString("en-IN")}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div className="rounded-2xl border border-border bg-card p-5 shadow-soft">
              <p className="mb-3 text-sm font-bold">Retailer Summary</p>
              <div className="flex items-center gap-3">
                <div className="relative h-36 w-36 shrink-0">
                  <ResponsiveContainer width="100%" height="100%">
                    <PieChart>
                      <Pie data={[{ name: "Active", value: m.activeRetailers }, { name: "Inactive", value: m.inactiveRetailers }]} dataKey="value" innerRadius={44} outerRadius={64} paddingAngle={2}>
                        <Cell fill="#22c55e" /><Cell fill="#ef4444" />
                      </Pie>
                      <Tooltip />
                    </PieChart>
                  </ResponsiveContainer>
                  <div className="pointer-events-none absolute inset-0 grid place-items-center"><div className="text-center"><p className="text-lg font-extrabold">{m.totalRetailers}</p><p className="text-[9px] text-muted-foreground">Total Retailers</p></div></div>
                </div>
                <div className="space-y-2 text-sm">
                  <div className="flex items-center gap-2"><span className="h-2.5 w-2.5 rounded-full bg-emerald-500" /><span className="text-muted-foreground">Active Retailers</span></div>
                  <p className="pl-4 font-extrabold">{m.activeRetailers} <span className="text-[11px] font-medium text-muted-foreground">({m.totalRetailers ? ((m.activeRetailers / m.totalRetailers) * 100).toFixed(1) : 0}%)</span></p>
                  <div className="flex items-center gap-2"><span className="h-2.5 w-2.5 rounded-full bg-rose-500" /><span className="text-muted-foreground">Inactive Retailers</span></div>
                  <p className="pl-4 font-extrabold">{m.inactiveRetailers} <span className="text-[11px] font-medium text-muted-foreground">({m.totalRetailers ? ((m.inactiveRetailers / m.totalRetailers) * 100).toFixed(1) : 0}%)</span></p>
                </div>
              </div>
              <p className="mt-3 border-t border-border pt-2 text-center text-xs font-semibold text-muted-foreground">Total Retailers <span className="font-extrabold text-foreground">{m.totalRetailers}</span></p>
            </div>

            <div className="rounded-2xl border border-border bg-card p-5 shadow-soft">
              <p className="mb-3 text-sm font-bold">Top Districts by Business Volume</p>
              <div className="h-52">
                {m.districts.length === 0 ? <div className="grid h-full place-items-center text-xs text-muted-foreground">No data</div> : (
                  <ResponsiveContainer width="100%" height="100%">
                    <BarChart data={m.districts} layout="vertical" margin={{ top: 4, right: 56, left: 8, bottom: 0 }}>
                      <XAxis type="number" hide tickFormatter={(v) => inrK(v)} />
                      <YAxis type="category" dataKey="name" tickLine={false} axisLine={false} width={92} className="text-[11px]" />
                      <Tooltip formatter={(v: number) => inr(v)} contentStyle={{ borderRadius: 8, border: "1px solid hsl(var(--border))", fontSize: 12 }} />
                      <Bar dataKey="value" radius={[0, 4, 4, 0]}>
                        {m.districts.map((d, i) => <Cell key={i} fill={d.name === "Others" ? "#94a3b8" : "#3b82f6"} />)}
                        <LabelList dataKey="value" position="right" formatter={(v: number) => inrK(v)} className="fill-muted-foreground text-[10px] font-semibold" />
                      </Bar>
                    </BarChart>
                  </ResponsiveContainer>
                )}
              </div>
            </div>
          </div>
        </>
      )}
    </div>
  );
}

function BarIcon() {
  return <Award className="h-5 w-5" />;
}
